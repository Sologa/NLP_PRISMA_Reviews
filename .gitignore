# ==== Core files to exclude for GitHub upload ====
*.pdf
*.zip
*.log
*.pyc

# Bytecode/cache
__pycache__/
*.DS_Store
.DS_Store
.vscode/

# Secrets / environment
.env

# Keep refs mostly as metadata only (json/jsonl)
refs/
!refs/*/
!refs/*/metadata/
!refs/*/metadata/*.jsonl
!refs/*/metadata/*.json

# Exclude markdown outputs and generated content under refs
refs/*/mds/
refs/*/tex_src/

# Exclude LaTeX / style sources and build artifacts
*.tex
*.sty
*.cls
*.bst
*.bbx
*.cbx
*.ins
*.dtx
*.bbl

# Exclude legacy/legacy-style scratch data
refs_old/

# Exclude generated/vendor temp outputs
results/
!screening/results/
!screening/results/**/*.json
!screening/results/**/*.jsonl
screening/results/**/batch_jobs/**/input.jsonl
screening/results/**/batch_jobs/**/output.jsonl
screening/results/**/batch_jobs/**/error.jsonl
screening/results/**/batch_jobs/**/upload_file.json
screening/results/**/batch_jobs/**/batch_create.json
screening/results/**/batch_jobs/**/parsed_results.json
screening/results/**/papers/**/fulltext_resolution_audit.json
arxiv_tex_source_attempt/

# Local tool/project metadata
.specstory/

# temp downloads and outputs
2601_query_reconstruction/
