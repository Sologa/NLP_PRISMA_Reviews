{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NLP PRISMA evidence synthesis object",
  "description": "Generic evidence synthesis object for stage-specific QA -> synthesis -> criteria evaluation.",
  "type": "object",
  "required": [
    "paper_id",
    "stage",
    "criteria_source",
    "input_scope",
    "field_results",
    "unresolved_fields",
    "conflicting_fields",
    "stage_handoff"
  ],
  "properties": {
    "paper_id": {
      "type": "string"
    },
    "stage": {
      "type": "string",
      "enum": [
        "stage1",
        "stage2"
      ]
    },
    "criteria_source": {
      "type": "string"
    },
    "input_scope": {
      "type": "string",
      "enum": [
        "title_abstract",
        "full_text"
      ]
    },
    "metadata_context": {
      "type": "object",
      "description": "Optional metadata captured outside the QA content layer. For 2511 these are descriptive only.",
      "additionalProperties": true
    },
    "field_results": {
      "type": "object",
      "description": "One entry per evidence field.",
      "additionalProperties": {
        "$ref": "#/$defs/field_result"
      }
    },
    "unresolved_fields": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "conflicting_fields": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "criteria_evaluation_ready": {
      "type": "boolean",
      "description": "Whether downstream criteria evaluation can proceed without manual backfill."
    },
    "stage_handoff": {
      "$ref": "#/$defs/stage_handoff"
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "quote_item": {
      "type": "object",
      "required": [
        "quote",
        "location"
      ],
      "properties": {
        "quote": {
          "type": "string"
        },
        "location": {
          "type": "string"
        },
        "evidence_role": {
          "type": "string",
          "enum": [
            "positive",
            "negative",
            "context",
            "conflict"
          ]
        }
      },
      "additionalProperties": false
    },
    "field_result": {
      "type": "object",
      "required": [
        "answer",
        "state",
        "supporting_quotes",
        "missingness_reason",
        "resolution_status",
        "criterion_refs"
      ],
      "properties": {
        "answer": {
          "type": "string"
        },
        "state": {
          "type": "string",
          "enum": [
            "present",
            "absent",
            "unclear",
            "not_observable"
          ]
        },
        "supporting_quotes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/quote_item"
          }
        },
        "missingness_reason": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "not_stated",
            "not_found",
            "conflicting",
            "metadata_only",
            "stage1_not_observable",
            null
          ]
        },
        "conflict_note": {
          "type": [
            "string",
            "null"
          ]
        },
        "resolution_status": {
          "type": "string",
          "enum": [
            "resolved",
            "defer_to_stage2",
            "needs_senior_review"
          ]
        },
        "criterion_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "stage_handoff": {
      "type": "object",
      "required": [
        "carry_forward_fields",
        "fulltext_only_fields",
        "notes_for_next_stage"
      ],
      "properties": {
        "carry_forward_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fulltext_only_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes_for_next_stage": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "senior_focus_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}